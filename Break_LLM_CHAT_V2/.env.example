# ============================================================
# Break_LLM_CHAT_V2 환경 설정
# 이 파일을 .env로 복사하고 값을 채워넣으세요.
# ============================================================

# ----------------------------------------------------------
# 오케스트레이터 LLM (사내 API 모델 — 낮은 성능)
# OpenAI API 호환 엔드포인트 (vLLM, LMStudio, 사내 프록시 등)
# ----------------------------------------------------------
VLLM_BASE_URL=http://10.0.0.5:8000/v1
VLLM_MODEL=mistral-7b-instruct
VLLM_API_KEY=EMPTY

# ----------------------------------------------------------
# 웹 채팅 LLM (고성능 reasoning 모델 — Selenium으로 제어)
# ----------------------------------------------------------
LLM_CHAT_URL=http://internal-llm-chat/
LLM_CHAT_HEADLESS=false
LLM_CHAT_PAGE_LOAD_WAIT=3

# ----------------------------------------------------------
# 에이전트 동작
# AGENT_USE_REACT: "auto" | "true" | "false"
#   auto  — tool-calling 시도, 실패 시 ReAct로 자동 폴백
#   true  — ReAct 강제 (항상 동작)
#   false — tool-calling 강제 (모델이 지원해야 함)
# ----------------------------------------------------------
AGENT_MAX_ITERATIONS=10
AGENT_VERBOSE=true
AGENT_USE_REACT=auto

# ----------------------------------------------------------
# Selector 자동 발견 (self-healing)
# SELECTOR_FAILURE_THRESHOLD: N회 실패 시 자동 재발견 트리거
# ----------------------------------------------------------
SELECTOR_DISCOVERY_ENABLED=true
SELECTOR_HTML_MAX_CHARS=60000
SELECTOR_FAILURE_THRESHOLD=3
SELECTOR_CACHE_FILE=selector_cache.json

# ----------------------------------------------------------
# Trace 로깅
# 각 세션의 단계별 실행 로그가 TRACE_LOG_DIR/*.txt에 저장됩니다.
# ----------------------------------------------------------
TRACE_LOG_DIR=trace_log
